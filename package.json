{
  "name": "bpmnlint-intl",
  "description": "BPMN validation via configurable lint rules with multi-language support. (bpmnlint fork)",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./config/*": "./config/*",
    "./rules/*": "./rules/*"
  },
  "keywords": [
    "bpmnlint",
    "bpmn",
    "linter",
    "cli",
    "validation",
    "rules"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ayvanov/bpmnlint-intl"
  },
  "author": "Alexander Ivanov <xanderinho@gmail.com>",
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "engines": {
    "node": ">= 20"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "all": "run-s lint lint:types test-coverage",
    "lint": "eslint .",
    "lint:types": "tsc",
    "dev": "npm test -- --watch",
    "test": "mocha --exclude \"test/integration/*/**\" \"test/**/*.*js\"",
    "test-coverage": "nyc --reporter=lcov --reporter=html npm test",
    "generate-docs-images": "npx @bpmn-io/bpmnlint-generate-docs-images ."
  },
  "dependencies": {
    "bpmnlint-utils": "^1.1.1",
    "min-dash": "^5.0.0"
  },
  "devDependencies": {
    "@bpmn-io/bpmnlint-generate-docs-images": "^1.2.0",
    "@bpmn-io/moddle-utils": "^0.3.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "ansi-colors": "^4.1.3",
    "bpmn-moddle": "^10.0.0",
    "chai": "^6.2.2",
    "cli-table": "^0.3.11",
    "color-support": "^1.1.3",
    "eslint": "^9.39.2",
    "eslint-plugin-bpmn-io": "^2.2.0",
    "execa": "^9.6.1",
    "install-local": "^4.1.0",
    "mocha": "^11.7.5",
    "mri": "^1.2.0",
    "npm-run-all2": "^8.0.4",
    "nyc": "^17.1.0",
    "pluralize": "^8.0.0",
    "strip-indent": "^4.1.1",
    "tiny-glob": "^0.2.9",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "config",
    "rules"
  ]
}
