{
  "compilerOptions": {
    "lib": ["DOM", "ES2020"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "./lib/**/*.d.ts",
    "./lib/**/*.js",
    "./rules/*.js",
    "./rules/locales/*.js",
    "./config/*.js",
    "./bin/*.js",
  ],
}
